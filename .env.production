# GoatCounter analytics — only active in production builds. The endpoint is
# a public URL (the GoatCounter site code), no secrets. See §24 of the design
# doc for the privacy posture (no PII, no cookies, honors DNT).
VITE_ANALYTICS_ENABLED=true
VITE_GOATCOUNTER_ENDPOINT=https://pathtothefuture.goatcounter.com/count
